{
  "name": "nearbytes-benchmarks",
  "version": "0.1.0",
  "description": "Performance harness and campaign tooling for Nearbytes friend-carriage sync",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "bench:campaign": "node scripts/bench-campaign.mjs",
    "bench:sync": "node dist/sync-benchmark.js",
    "bench:sync:merge": "node scripts/merge-benchmark-results.mjs",
    "bench:sync:figures": "node scripts/render-benchmark-figures.mjs",
    "report:figures": "node scripts/report-figures.mjs",
    "e2e:bidirectional:local": "node tests/e2e/sync-bidirectional-local.mjs",
    "e2e:sibling:local": "node tests/e2e/sync-sibling-local.mjs",
    "e2e:campaign:local": "node tests/e2e/sync-metrics-campaign-local.mjs",
    "e2e:campaign:multi": "node tests/e2e/sync-metrics-campaign-multi.mjs",
    "e2e:local": "node tests/e2e/sync-metrics-local.mjs",
    "e2e:propagation:local": "node tests/e2e/event-propagation-local.mjs",
    "e2e:propagation:remote": "node tests/e2e/event-propagation-remote.mjs",
    "e2e:remote": "node tests/e2e/sync-metrics-remote.mjs",
    "e2e:remote:campaign": "node tests/e2e/sync-metrics-remote.mjs --campaign",
    "bench:sync:quick": "NEARBYTES_BENCH_QUICK=1 node dist/sync-benchmark.js",
    "bench:sync:campaign": "NEARBYTES_BENCH_PROFILE=campaign node dist/sync-benchmark.js",
    "bench:network:local": "node scripts/network-bench/run-local.mjs",
    "bench:network:lan": "node scripts/network-bench/run-lan.mjs",
    "bench:network:wan": "node scripts/network-bench/run-wan.mjs",
    "bench:protocol:clean": "node scripts/protocol-bench/clean.mjs",
    "bench:protocol:local": "node scripts/protocol-bench/run-local.mjs",
    "bench:protocol:lan": "node scripts/protocol-bench/run-lan.mjs",
    "refresh": "node scripts/refresh.mjs",
    "update": "node scripts/update.mjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nearbytes-chat": "github:nearbytes/nearbytes-chat",
    "nearbytes-crypto": "github:nearbytes/nearbytes-crypto",
    "nearbytes-engine": "github:nearbytes/nearbytes-engine",
    "nearbytes-files": "github:nearbytes/nearbytes-files",
    "nearbytes-log": "github:nearbytes/nearbytes-log",
    "nearbytes-skeleton": "github:nearbytes/nearbytes-skeleton"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "yarn@4.15.0"
}
