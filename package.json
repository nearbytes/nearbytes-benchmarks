{
  "name": "nearbytes-benchmarks",
  "version": "0.1.0",
  "description": "Performance harness and campaign tooling for Nearbytes friend-carriage sync",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "bench:paper": "node scripts/bench-paper-campaign.mjs",
    "bench:sync": "node dist/sync-benchmark.js",
    "bench:sync:merge": "node scripts/merge-benchmark-results.mjs",
    "bench:sync:figures": "node scripts/render-benchmark-figures.mjs",
    "paper:figures": "node scripts/paper-figures.mjs",
    "e2e:paper:local": "node tests/e2e/sync-metrics-paper-local.mjs",
    "e2e:paper:campaign": "node tests/e2e/sync-metrics-paper-campaign.mjs",
    "e2e:local": "node tests/e2e/sync-metrics-local.mjs",
    "e2e:remote": "node tests/e2e/sync-metrics-remote.mjs",
    "e2e:remote:paper": "node tests/e2e/sync-metrics-remote.mjs --paper",
    "bench:sync:quick": "NEARBYTES_BENCH_QUICK=1 node dist/sync-benchmark.js",
    "bench:sync:paper": "NEARBYTES_BENCH_PROFILE=paper node dist/sync-benchmark.js"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nearbytes-crypto": "file:../nearbytes-crypto",
    "nearbytes-files": "file:../nearbytes-files",
    "nearbytes-log": "file:../nearbytes-log",
    "nearbytes-skeleton": "file:../nearbytes-skeleton"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  }
}
