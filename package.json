{
  "name": "nearbytes-benchmarks",
  "version": "0.1.0",
  "description": "Performance harness and campaign tooling for Nearbytes friend-carriage sync",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "bench": "node scripts/protocol-bench/run-transfer-matrix-all.mjs",
    "bench:local": "node scripts/protocol-bench/run-transfer-matrix.mjs -- --categories local --out .local/bench/protocol/transfer-matrix-local.json",
    "bench:lan": "bash scripts/protocol-bench/run-transfer-matrix-lan-detached.sh",
    "bench:wan": "node scripts/protocol-bench/run-transfer-matrix.mjs -- --categories wan --out .local/bench/protocol/transfer-matrix-wan.json",
    "bench:lan:pull": "bash scripts/protocol-bench/pull-transfer-matrix-lan.sh",
    "bench:lan:finish-paper": "bash scripts/finish-lan-paper.sh",
    "bench:campaign": "node scripts/bench-campaign.mjs",
    "bench:sync": "node dist/sync-benchmark.js",
    "bench:sync:merge": "node scripts/merge-benchmark-results.mjs",
    "bench:sync:figures": "node scripts/render-benchmark-figures.mjs",
    "report:figures": "node scripts/report-figures.mjs",
    "e2e:bidirectional:local": "node tests/e2e/sync-bidirectional-local.mjs",
    "e2e:sibling:local": "node tests/e2e/sync-sibling-local.mjs",
    "e2e:campaign:local": "node tests/e2e/sync-metrics-campaign-local.mjs",
    "e2e:campaign:multi": "node tests/e2e/sync-metrics-campaign-multi.mjs",
    "e2e:local": "node tests/e2e/sync-metrics-local.mjs",
    "e2e:propagation:local": "node tests/e2e/event-propagation-local.mjs",
    "e2e:propagation:remote": "node tests/e2e/event-propagation-remote.mjs",
    "e2e:remote": "node tests/e2e/sync-metrics-remote.mjs",
    "e2e:remote:campaign": "node tests/e2e/sync-metrics-remote.mjs --campaign",
    "bench:sync:quick": "NEARBYTES_BENCH_QUICK=1 node dist/sync-benchmark.js",
    "bench:sync:campaign": "NEARBYTES_BENCH_PROFILE=campaign node dist/sync-benchmark.js",
    "bench:network:local": "node scripts/network-bench/run-local.mjs",
    "bench:network:lan": "node scripts/network-bench/run-lan.mjs",
    "bench:network:wan": "node scripts/network-bench/run-wan.mjs",
    "bench:protocol:clean": "node scripts/protocol-bench/clean.mjs",
    "bench:protocol:local": "node scripts/protocol-bench/run-transfer-matrix.mjs -- --categories local --out .local/bench/protocol/transfer-matrix-local.json",
    "bench:protocol:lan": "bash scripts/protocol-bench/run-transfer-matrix-lan-detached.sh",
    "bench:protocol:wan": "node scripts/protocol-bench/run-transfer-matrix.mjs -- --categories wan --out .local/bench/protocol/transfer-matrix-wan.json",
    "bench:protocol:suite:local": "node scripts/protocol-bench/run-local.mjs",
    "bench:protocol:suite:lan": "node scripts/protocol-bench/run-lan.mjs",
    "bench:protocol:suite:wan": "node scripts/protocol-bench/run-wan.mjs",
    "bench:opt-ablation": "node scripts/protocol-bench/run-optimization-ablation.mjs",
    "bench:protocol:transfer-matrix": "node scripts/protocol-bench/run-transfer-matrix.mjs",
    "bench:protocol:transfer-matrix:lan:detached": "bash scripts/protocol-bench/run-transfer-matrix-lan-detached.sh",
    "bench:protocol:transfer-matrix:lan:pull": "bash scripts/protocol-bench/pull-transfer-matrix-lan.sh",
    "bench:protocol:transfer-matrix:lan:finish-paper": "bash scripts/finish-lan-paper.sh",
    "bench:protocol:lan-compare:detached": "bash scripts/protocol-bench/run-lan-compare-detached.sh",
    "bench:protocol:lan-compare:pull": "bash scripts/protocol-bench/pull-lan-compare.sh",
    "refresh": "node scripts/refresh.mjs",
    "update": "node scripts/update.mjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nearbytes-chat": "https://github.com/nearbytes/nearbytes-chat.git#commit=6892ff741b7af37796b529d04cbb00fe2064f3d3",
    "nearbytes-crypto": "github:nearbytes/nearbytes-crypto",
    "nearbytes-engine": "https://github.com/nearbytes/nearbytes-engine.git#commit=f6758f7726eaae3a5949937bf890ee92f02e29f1",
    "nearbytes-files": "https://github.com/nearbytes/nearbytes-files.git#commit=c08023fbe09571a819bb43a18ec2b477acb9e459",
    "nearbytes-log": "https://github.com/nearbytes/nearbytes-log.git#commit=0a1bef159ead34b542d20af74b8473e2232a90e2",
    "nearbytes-skeleton": "https://github.com/nearbytes/nearbytes-skeleton.git#commit=c6cf3e968c57e3c11bdfb913778befa53f4477bd"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "yarn@4.15.0"
}
