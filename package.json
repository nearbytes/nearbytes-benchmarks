{
  "name": "nearbytes-benchmarks",
  "version": "0.1.0",
  "description": "Performance harness and campaign tooling for Nearbytes friend-carriage sync",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "bench:campaign": "node scripts/bench-campaign.mjs",
    "bench:sync": "node dist/sync-benchmark.js",
    "bench:sync:merge": "node scripts/merge-benchmark-results.mjs",
    "bench:sync:figures": "node scripts/render-benchmark-figures.mjs",
    "report:figures": "node scripts/report-figures.mjs",
    "e2e:bidirectional:local": "node tests/e2e/sync-bidirectional-local.mjs",
    "e2e:campaign:local": "node tests/e2e/sync-metrics-campaign-local.mjs",
    "e2e:campaign:multi": "node tests/e2e/sync-metrics-campaign-multi.mjs",
    "e2e:local": "node tests/e2e/sync-metrics-local.mjs",
    "e2e:remote": "node tests/e2e/sync-metrics-remote.mjs",
    "e2e:remote:campaign": "node tests/e2e/sync-metrics-remote.mjs --campaign",
    "bench:sync:quick": "NEARBYTES_BENCH_QUICK=1 node dist/sync-benchmark.js",
    "bench:sync:campaign": "NEARBYTES_BENCH_PROFILE=campaign node dist/sync-benchmark.js"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nearbytes-crypto": "github:nearbytes/nearbytes-crypto#main",
    "nearbytes-files": "github:nearbytes/nearbytes-files#main",
    "nearbytes-log": "github:nearbytes/nearbytes-log#main",
    "nearbytes-skeleton": "github:nearbytes/nearbytes-skeleton#main"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  }
}
